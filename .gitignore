# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Notebook checkpoints
.ipynb_checkpoints/

# IDE and editor settings
.vscode/
.idea/

# Logs and local runtime files
*.log

# Public repo hygiene: keep generated analysis and raw inputs out of sync
/analysis/
/data/

# Keep reference docs out of public sync
/docs/reference/
